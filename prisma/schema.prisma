// ── générateur JavaScript/TypeScript ───────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
  // binaryTargets  = ["native"]
}

// ── source de données PostgreSQL ───────────────────────────────────────────────
// connection URL is now moved to `prisma.config.ts` (required by Prisma 7+)
// see https://pris.ly/d/config-datasource
datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordhash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Manufacturer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  website   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}
model Product {
  id              Int      @id @default(autoincrement())
  manufacturer    Manufacturer @relation(fields: [manufacturer_id], references: [id])
  manufacturer_id Int
  product_type    String
  name            String
  sku             String    @unique
  image_url       String?   // ← nullable
  warranty        String?   // ← nullable
  scraped_url     String?   // ← utile pour le debug/re-scraping
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  productServer      Product_server?
  productSwitch      Product_switch?        // ← renommé
  productRouter      Product_router?        // ← séparé
  productAccessPoint Product_access_point?  // ← singulier
}

model Product_server {
  product_id           Int      @id
  product              Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // CPU
  cpu_model            String?
  cpu_cores            Int?
  cpu_frequency        String?
  cpu_socket           String?

  // RAM
  ram_gb               Int?
  ram_type             String?
  ram_max_gb           Int?
  ram_slots_total      Int?
  ram_slots_available  Int?

  // Stockage
  storage_slots_total  Int?
  storage_bays         Json?    // [{"type":"3.5","count":1},{"type":"M.2","count":2}]
  storage_capacity     String?
  storage_connector    String?

  // Boîtier
  rack_units           Int?
  case_format          String?
  server_format        String?  // Tour / Rack / Blade

  // Réseau
  lan_ports            Json?    // [{"type":"RJ45","count":2,"speed_mbps":1000}]

  // Alimentation
  power_watts          Int?
  redundant_psu        Boolean  @default(false)

  // Connectique
  front_connectors     Json?
  rear_connectors      Json?

  // Divers
  barebone             Boolean  @default(false)
  os_included          Boolean  @default(false)

  // Dimensions
  height_mm            Int?
  width_mm             Int?
  depth_mm             Int?
}

model Product_switch {
  product_id           Int      @id
  product              Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // Ports
  lan_ports            Json?    // [{"type":"RJ45","count":48,"speed_mbps":1000}]
  console_port         Boolean  @default(false)

  // Switching
  switching_capacity_gbps Int?
  layer                Int?     // 2 ou 3
  managed              Boolean  @default(false)
  stacking             Boolean  @default(false)
  vlan_support         Boolean  @default(false)

  // PoE
  poe_support          Boolean  @default(false)
  poe_budget_watts     Int?

  // Boîtier
  rack_units           Int?
  power_watts          Int?
  redundant_psu        Boolean  @default(false)

  height_mm            Int?
  width_mm             Int?
  depth_mm             Int?
}

model Product_router {
  product_id              Int     @id
  product                 Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  // WAN (modem uniquement)
  wan_ports               Json?    // [{"type":"RJ45","count":1,"speed_mbps":1000}]
  modem_type              String?  // "ADSL" | "VDSL" | "FTTH" | "4G" | "5G"
  modem_integrated        Boolean  @default(false) // true = box ISP type

  // LAN
  lan_ports               Json?    // [{"type":"RJ45","count":4,"speed_mbps":1000}]
  console_port            Boolean  @default(false)

  // Wifi intégré (optionnel)
  wifi_standard           String?  // "WiFi 6" | "WiFi 6E" | null si pas de wifi
  wifi_bands              String[] // ["2.4GHz", "5GHz"]

  // Routing
  layer                   Int?     // toujours 3 mais on garde pour cohérence
  managed                 Boolean  @default(false)
  vlan_support            Boolean  @default(false)
  vpn_support             Boolean  @default(false)
  routing_protocols       String[] // ["BGP", "OSPF", "MPLS", "RIP"]
  max_throughput_mbps     Int?

  // PoE
  poe_support             Boolean  @default(false)
  poe_budget_watts        Int?

  // Boîtier
  rack_units              Int?
  power_watts             Int?
  redundant_psu           Boolean  @default(false)

  height_mm               Int?
  width_mm                Int?
  depth_mm                Int?
}

model Product_access_point {
  product_id           Int      @id
  product              Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  wifi_standard        String?
  wifi_bands           String[] // ["2.4GHz","5GHz","6GHz"]
  max_throughput_mbps  Int?
  ethernet_ports       Int?
  poe_support          Boolean  @default(false)
  poe_in               Boolean  @default(false)
  antennas             Int?
  mu_mimo              String?
  mounting             String?
  power_watts          Int?
  outdoor              Boolean  @default(false)
}